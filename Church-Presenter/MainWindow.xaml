<Window x:Class="Church_Presenter.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Church Presenter" Height="800" Width="1300" MinHeight="650" MinWidth="1000" Background="#F8FAFC" WindowState="Maximized">
 <Window.Resources>
  <Style TargetType="Button"><Setter Property="Padding" Value="12,8"/><Setter Property="Margin" Value="4"/><Setter Property="FontFamily" Value="Segoe UI Variable"/><Setter Property="Cursor" Value="Hand"/></Style>
  <Style x:Key="Nav" TargetType="Button"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#CBD5E1"/><Setter Property="BorderThickness" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="FontSize" Value="15"/><Setter Property="Padding" Value="16,12"/><Setter Property="Margin" Value="6,3"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1E293B"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
  <Style x:Key="BibleCard" TargetType="Border"><Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#E8E9F2"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="16"/><Setter Property="Effect"><Setter.Value><DropShadowEffect ShadowDepth="1" BlurRadius="10" Opacity="0.06"/></Setter.Value></Setter></Style>
  <Style x:Key="PurpleButton" TargetType="Button"><Setter Property="Background" Value="#6153EE"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="18,11"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4E42D7"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
  <Style x:Key="BibleSearch" TargetType="TextBox"><Setter Property="Background" Value="#FAFAFD"/><Setter Property="BorderBrush" Value="#E4E5ED"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="10,8"/><Setter Property="FontSize" Value="13"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}"><ScrollViewer x:Name="PART_ContentHost"/></Border></ControlTemplate></Setter.Value></Setter></Style>
  <Style x:Key="BibleTool" TargetType="Button"><Setter Property="Foreground" Value="#5B5CEB"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="18"/><Setter Property="Padding" Value="5"/></Style>
  <Style TargetType="TextBox"><Setter Property="Padding" Value="8"/><Setter Property="Margin" Value="4"/></Style>
  <Style TargetType="ComboBox"><Setter Property="Padding" Value="7"/><Setter Property="Margin" Value="4"/></Style>
 </Window.Resources>
 <Grid>
  <Grid.ColumnDefinitions>
    <ColumnDefinition Width="220"/>
    <ColumnDefinition Width="*"/>
  </Grid.ColumnDefinitions>

  <Border Background="#0F172A">
    <DockPanel>
      <StackPanel DockPanel.Dock="Top" Margin="20,28,12,18">
        <TextBlock Text="CHURCH" Foreground="#38BDF8" FontWeight="Bold" FontSize="14"/>
        <TextBlock Text="Presenter" Foreground="White" FontWeight="SemiBold" FontSize="26"/>
      </StackPanel>
      <StackPanel>
        <Button Style="{StaticResource Nav}" Click="Dashboard_Click">Dashboard</Button>
        <Button Style="{StaticResource Nav}" Click="Planner_Click">Planner</Button>
        <Button Style="{StaticResource Nav}" Click="SongLibrary_Click" Background="#463493" Foreground="White">Song Library</Button>
        <Button Style="{StaticResource Nav}" Click="Bible_Click">Bible Library</Button>
        <Button Style="{StaticResource Nav}" Click="MediaLibrary_Click">Media Library</Button>
        <Button Style="{StaticResource Nav}" Click="Theme_Click">Themes</Button>
        <Button Style="{StaticResource Nav}" Click="Settings_Click">Settings</Button>
      </StackPanel>
      <TextBlock DockPanel.Dock="Bottom" Margin="20" Text="OFFLINE • SQLITE" Foreground="#64748B" FontSize="11"/>
    </DockPanel>
  </Border>

  <Grid Grid.Column="1" Margin="30">

   <Grid x:Name="DashboardPanel" Visibility="Collapsed">
     <StackPanel>
       <TextBlock Text="Good morning" FontSize="31" FontWeight="SemiBold"/>
       <TextBlock Text="Prepare a calm, focused service." Foreground="#64748B" Margin="0,6,0,24"/>
       <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="24">
         <StackPanel>
           <TextBlock Text="TODAY'S PLANNER" Foreground="#64748B" FontSize="12" FontWeight="Bold"/>
           <TextBlock Text="Create a service planner, then add components." FontSize="20" Margin="0,12,0,14"/>
           <Button Content="New Planner" Click="Planner_Click" Background="#0284C7" Foreground="White" HorizontalAlignment="Left"/>
         </StackPanel>
       </Border>
     </StackPanel>
   </Grid>

   <Grid x:Name="PlannerPanel" Visibility="Collapsed" xmlns:planner="clr-namespace:Church_Presenter.Views.Planner">
    <planner:PlannerView/>
    <StackPanel Visibility="Collapsed">
      <DatePicker x:Name="ServiceDatePicker" />
      <TextBox x:Name="ServiceNameBox" />
      <ListBox x:Name="PlannerList" />
      <TextBlock x:Name="ComponentTypeLabel" />
      <TextBox x:Name="ComponentTitleBox" />
      <TextBox x:Name="ComponentContentBox" />
    </StackPanel>
  </Grid>

   <Grid x:Name="BiblePanel" Visibility="Collapsed" Background="#FCFCFE">
     <Grid.RowDefinitions>
       <RowDefinition Height="Auto"/>
       <RowDefinition Height="Auto"/>
       <RowDefinition Height="*"/>
     </Grid.RowDefinitions>
     <DockPanel Margin="8,0,8,18">
       <StackPanel Orientation="Horizontal">
        <Border Width="52" Height="52" CornerRadius="12" Background="#F0EDFF" Margin="0,0,12,0"><TextBlock Text="&#x1F4D6;" FontSize="27" Foreground="#6153EE" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
        <StackPanel><TextBlock Text="Bible Library" FontSize="30" FontWeight="SemiBold" Foreground="#15155A"/><TextBlock Text="Manage Bible books, chapters and verses" Foreground="#66708A" FontSize="14" Margin="0,3,0,0"/></StackPanel>
       </StackPanel>
       <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
        <Border Width="370" Height="43" Background="White" BorderBrush="#E2E4ED" BorderThickness="1" CornerRadius="8" Margin="0,0,8,0"><Grid><TextBlock Text="⌕" FontSize="22" Foreground="#69738D" VerticalAlignment="Center" Margin="12,0,0,0"/><TextBox x:Name="SearchBox" TextChanged="Search_Changed" ToolTip="Search Bible text" BorderThickness="0" Background="Transparent" Margin="38,0,6,0" VerticalContentAlignment="Center" FontSize="13"/></Grid></Border>
        <Button Content="＋ Add Bible" Click="ImportBible_Click" Style="{StaticResource PurpleButton}"/>
       </StackPanel>
     </DockPanel>
     <Border Grid.Row="1" Background="White" BorderBrush="#E9EAF1" BorderThickness="0,0,0,1" Padding="8,0,0,4">
      <StackPanel Orientation="Horizontal"><Border Background="#F0EDFF" CornerRadius="7" Padding="14,10" Margin="0,0,14,0"><TextBlock Text="▣  Bible Structure" Foreground="#5B4DEA" FontWeight="SemiBold"/></Border><TextBlock Text="⌕  Search" VerticalAlignment="Center" Foreground="#4E5873"/></StackPanel>
     </Border>
     <Grid Grid.Row="2" Margin="0,16,0,0">
      <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="142"/></Grid.RowDefinitions>
      <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1.45*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource BibleCard}" Margin="0,0,8,0"><DockPanel>
       <Grid DockPanel.Dock="Top"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="▯  Testaments    2" FontSize="15" FontWeight="SemiBold" Foreground="#15155A"/><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="＋" Style="{StaticResource BibleTool}"/><Button Content="✎" Style="{StaticResource BibleTool}"/><Button Content="♙" Style="{StaticResource BibleTool}" Foreground="#EF4444"/></StackPanel></Grid>
       <TextBlock DockPanel.Dock="Top" Text="The Bible has two testaments" Foreground="#67718B" FontSize="13" Margin="0,15,0,16"/>
       <StackPanel><Border BorderBrush="#7466FF" BorderThickness="1.5" Background="#F7F5FF" CornerRadius="8" Padding="14" Margin="0,0,0,12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="📜" FontSize="30"/><StackPanel Grid.Column="1"><TextBlock Text="Old Testament" FontWeight="SemiBold" Foreground="#191963"/><TextBlock Text="39 Books" Foreground="#69728D" Margin="0,7,0,0"/></StackPanel><Border Grid.Column="2" Background="#ECEBFA" CornerRadius="12" Padding="8,3"><TextBlock Text="39" Foreground="#5044DE" FontWeight="SemiBold"/></Border></Grid></Border><Border BorderBrush="#E9EAF1" BorderThickness="1" Background="White" CornerRadius="8" Padding="14"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="✝" FontSize="34" Foreground="#6B5CFF"/><StackPanel Grid.Column="1"><TextBlock Text="New Testament" FontWeight="SemiBold" Foreground="#191963"/><TextBlock Text="27 Books" Foreground="#69728D" Margin="0,7,0,0"/></StackPanel><Border Grid.Column="2" Background="#F0F1F5" CornerRadius="12" Padding="8,3"><TextBlock Text="27" Foreground="#4A5270" FontWeight="SemiBold"/></Border></Grid></Border></StackPanel>
      </DockPanel></Border>
      <Border Grid.Column="1" Style="{StaticResource BibleCard}" Margin="8,0"><DockPanel><Grid DockPanel.Dock="Top"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="▦  Books    66" FontSize="15" FontWeight="SemiBold" Foreground="#15155A"/><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="＋" Style="{StaticResource BibleTool}"/><Button Content="✎" Style="{StaticResource BibleTool}"/></StackPanel></Grid><TextBox DockPanel.Dock="Top" Style="{StaticResource BibleSearch}" Text="Search Book" Foreground="#7D859D" Margin="0,16,0,10"/><ComboBox x:Name="BookBox" DisplayMemberPath="Name" SelectionChanged="Book_Changed" BorderThickness="0" Background="Transparent" FontSize="14"/></DockPanel></Border>
      <Border Grid.Column="2" Style="{StaticResource BibleCard}" Margin="8,0"><DockPanel><Grid DockPanel.Dock="Top"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="▤  Chapters" FontSize="15" FontWeight="SemiBold" Foreground="#15155A"/><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="＋" Style="{StaticResource BibleTool}"/><Button Content="✎" Style="{StaticResource BibleTool}"/></StackPanel></Grid><TextBox DockPanel.Dock="Top" Style="{StaticResource BibleSearch}" Text="Search Chapter" Foreground="#7D859D" Margin="0,16,0,10"/><ComboBox x:Name="ChapterBox" SelectionChanged="Chapter_Changed" BorderThickness="0" Background="Transparent" FontSize="14"/></DockPanel></Border>
      <Border Grid.Column="3" Style="{StaticResource BibleCard}" Margin="8,0,0,0"><DockPanel><Grid DockPanel.Dock="Top"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="▯  Verses" FontSize="15" FontWeight="SemiBold" Foreground="#15155A"/><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="＋" Style="{StaticResource BibleTool}"/><Button Content="✎" Style="{StaticResource BibleTool}"/></StackPanel></Grid><TextBox DockPanel.Dock="Top" Style="{StaticResource BibleSearch}" Text="Search Verse" Foreground="#7D859D" Margin="0,16,0,8"/><ListBox x:Name="VerseList" SelectionChanged="Verse_Selected" BorderThickness="0" Background="Transparent"><ListBox.ItemTemplate><DataTemplate><Border BorderBrush="#ECECF2" BorderThickness="0,0,0,1" Padding="4,10"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/></Grid.ColumnDefinitions><Border Width="28" Height="28" Background="#F0EDFF" CornerRadius="6"><TextBlock Text="{Binding Verse}" Foreground="#5B4DEA" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/></Border><StackPanel Grid.Column="1"><TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="#343950" FontSize="13"/></StackPanel><TextBlock Grid.Column="2" Text="•••" Foreground="#59617A"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox></DockPanel></Border>
      <Border Grid.Row="1" Grid.ColumnSpan="3" Style="{StaticResource BibleCard}" Margin="0,16,8,0"><DockPanel><TextBlock DockPanel.Dock="Top" Text="◉  Selected Reference Preview" FontWeight="SemiBold" Foreground="#15155A"/><StackPanel Margin="0,18,0,0"><TextBlock Text="Old Testament    ›    Genesis    ›    Chapter 1    ›    Verse 1" Foreground="#4E5873"/><TextBlock Text="Select a verse to preview it here." Foreground="#39425D" Margin="0,12,0,0" TextWrapping="Wrap"/></StackPanel></DockPanel></Border>
      <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource BibleCard}" Margin="8,16,0,0"><StackPanel><TextBlock Text="▯  Genesis" FontSize="16" FontWeight="SemiBold" Foreground="#15155A"/><TextBlock Text="Old Testament" Foreground="#66708A" Margin="0,8,0,0"/><TextBlock Text="50 Chapters  ·  1533 Verses" Foreground="#66708A" Margin="0,5,0,0"/></StackPanel></Border>
     </Grid>
   </Grid>

   <Grid x:Name="SettingsPanel" Visibility="Collapsed">
     <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Width="620">
       <TextBlock Text="Display settings" FontSize="31" FontWeight="SemiBold"/>
       <TextBlock Text="These defaults are saved locally and used by the fullscreen presentation window." Foreground="#64748B" Margin="0,6,0,20"/>
       <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20">
         <StackPanel>
           <TextBlock Text="Background color (hex)"/>
           <TextBox x:Name="BackgroundColorBox"/>
           <TextBlock Text="Font color (hex)" Margin="0,12,0,0"/>
           <TextBox x:Name="FontColorBox"/>
         </StackPanel>
       </Border>
       <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,16,0,0">
         <StackPanel>
           <TextBlock Text="Presentation font size"/>
           <Slider x:Name="FontSizeSlider" Minimum="24" Maximum="120" TickFrequency="2" IsSnapToTickEnabled="True" Margin="0,12"/>
           <TextBlock x:Name="FontSizeLabel"/>

           <TextBlock Text="Scroll speed (px / tick)" Margin="0,12,0,0"/>
           <Slider x:Name="ScrollSpeedSlider" Minimum="1" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,8"/>
           <TextBlock x:Name="ScrollSpeedLabel"/>

           <WrapPanel Margin="0,12,0,0">
             <Button Content="Save display settings" Click="SaveSettings_Click" Background="#0284C7" Foreground="White"/>
             <Button Content="Preview" Click="Preview_Click"/>
           </WrapPanel>
         </StackPanel>
       </Border>
       <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,16,0,0">
         <StackPanel>
           <TextBlock Text="Content-specific typography" FontSize="18" FontWeight="SemiBold"/>
           <TextBlock Text="Set a font size and hex color for each type of presentation content." Foreground="#64748B" Margin="0,4,0,12"/>
           <Grid>
             <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
             <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
             <TextBlock Grid.Column="1" Text="Font size" Margin="4"/><TextBlock Grid.Column="2" Text="Font color (hex)" Margin="4"/>
             <TextBlock Grid.Row="1" Text="Heading" VerticalAlignment="Center" Margin="4"/>
             <TextBox x:Name="HeadingFontSizeBox" Grid.Row="1" Grid.Column="1" ToolTip="Font size"/>
             <TextBox x:Name="HeadingFontColorBox" Grid.Row="1" Grid.Column="2" ToolTip="Hex color, e.g. #FFFFFF"/>
             <TextBlock Grid.Row="2" Text="Paragraph" VerticalAlignment="Center" Margin="4"/>
             <TextBox x:Name="ParagraphFontSizeBox" Grid.Row="2" Grid.Column="1" ToolTip="Font size"/>
             <TextBox x:Name="ParagraphFontColorBox" Grid.Row="2" Grid.Column="2" ToolTip="Hex color, e.g. #FFFFFF"/>
             <TextBlock Grid.Row="3" Text="Bible reading" VerticalAlignment="Center" Margin="4"/>
             <TextBox x:Name="BibleReadingFontSizeBox" Grid.Row="3" Grid.Column="1" ToolTip="Font size"/>
             <TextBox x:Name="BibleReadingFontColorBox" Grid.Row="3" Grid.Column="2" ToolTip="Hex color, e.g. #FFFFFF"/>
             <TextBlock Grid.Row="4" Text="Song lyrics" VerticalAlignment="Center" Margin="4"/>
             <TextBox x:Name="SongLyricsFontSizeBox" Grid.Row="4" Grid.Column="1" ToolTip="Font size"/>
             <TextBox x:Name="SongLyricsFontColorBox" Grid.Row="4" Grid.Column="2" ToolTip="Hex color, e.g. #FFFFFF"/>
           </Grid>
         </StackPanel>
       </Border>
      </StackPanel>
     </ScrollViewer>
   </Grid>

   <Grid x:Name="SongPanel" Background="#FCFCFE">
     <Grid.RowDefinitions>
       <RowDefinition Height="Auto"/>
       <RowDefinition Height="*"/>
       <RowDefinition Height="92"/>
     </Grid.RowDefinitions>
     <DockPanel Margin="8,0,8,18">
      <StackPanel Orientation="Horizontal"><Border Width="52" Height="52" Background="#F0EDFF" CornerRadius="12" Margin="0,0,12,0"><TextBlock Text="♫" FontSize="30" Foreground="#5B5CEB" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel><TextBlock Text="Song Library" FontSize="30" FontWeight="SemiBold" Foreground="#15155A"/><TextBlock Text="Add and manage songs used in worship services" Foreground="#66708A" FontSize="14" Margin="0,3,0,0"/></StackPanel></StackPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"><Border Width="350" Height="43" Background="White" BorderBrush="#E2E4ED" BorderThickness="1" CornerRadius="8" Margin="0,0,8,0"><Grid><TextBlock Text="⌕" FontSize="22" Foreground="#69738D" VerticalAlignment="Center" Margin="12,0,0,0"/><TextBlock Text="Search songs by title or lyrics" Foreground="#969CB1" VerticalAlignment="Center" Margin="40,0,0,0" FontSize="13"/></Grid></Border><Button Content="＋ Add Song" Style="{StaticResource PurpleButton}"/></StackPanel>
     </DockPanel>
     <Grid Grid.Row="1" Margin="0,0,0,12">
       <Grid.ColumnDefinitions>
         <ColumnDefinition Width="1.05*"/>
         <ColumnDefinition Width="1.32*"/>
         <ColumnDefinition Width="1.32*"/>
       </Grid.ColumnDefinitions>
       <Border Style="{StaticResource BibleCard}" Margin="0,0,8,0"><DockPanel><Grid DockPanel.Dock="Top"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Songs    128" FontSize="16" FontWeight="SemiBold" Foreground="#15155A"/><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="＋" Style="{StaticResource BibleTool}"/><Button Content="✎" Style="{StaticResource BibleTool}"/><Button Content="♙" Style="{StaticResource BibleTool}" Foreground="#EF4444"/></StackPanel></Grid><TextBox DockPanel.Dock="Top" Style="{StaticResource BibleSearch}" Text="⌕  Search songs" Foreground="#9299AD" Margin="0,16,0,10"/><ListBox x:Name="SongList" SelectionChanged="Song_Selected" BorderThickness="0" Background="Transparent"><ListBox.ItemTemplate><DataTemplate><Border Padding="10,9" CornerRadius="7"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="27"/><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="♫" Foreground="#695CF7" FontSize="17"/><TextBlock Grid.Column="1" Text="{Binding Id, StringFormat={}{0:000}}" Foreground="#626B85" FontSize="12" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding Title}" Foreground="#30364C" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/></Grid></Border><DataTemplate.Triggers><DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True"><Setter Property="Border.Background" Value="#E7E2FF"/></DataTrigger></DataTemplate.Triggers></DataTemplate></ListBox.ItemTemplate></ListBox></DockPanel></Border>
       <Border Grid.Column="1" Style="{StaticResource BibleCard}" Margin="8,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="♫  Song Details" FontSize="16" FontWeight="SemiBold" Foreground="#15155A"/><Grid Grid.Row="1" Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="72"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Song ID" Foreground="#4E5873" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="001" IsReadOnly="True" Background="#F2F3F7" BorderThickness="0"/></Grid><StackPanel Grid.Row="2" Margin="0,8,0,0"><TextBlock Text="Title *" Foreground="#4E5873"/><TextBox x:Name="SongTitleBox" Style="{StaticResource BibleSearch}" ToolTip="Song title" Margin="0,6,0,0"/></StackPanel><Grid Grid.Row="3" Margin="0,14,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="Lyrics *" Foreground="#4E5873"/><Border Grid.Row="1" Background="#F7F7FA" BorderBrush="#E2E3EB" BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Padding="8"><TextBlock Text="B     I     U     |     ☷     ☷                       ♫  Insert Chord" Foreground="#515A74"/></Border><TextBox x:Name="SongLyricsBox" Grid.Row="2" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" ToolTip="Lyrics (separate stanzas with blank lines)" BorderBrush="#E2E3EB" BorderThickness="1" Padding="12" FontSize="14"/></Grid><DockPanel Grid.Row="4" Margin="0,12,0,0"><CheckBox Content="Active" IsChecked="True" Foreground="#5A6279" VerticalAlignment="Center"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Cancel"/><Button Content="▣  Save" Click="SaveSong_Click" Style="{StaticResource PurpleButton}"/></StackPanel></DockPanel></Grid></Border>
       <Border Grid.Column="2" Style="{StaticResource BibleCard}" Margin="8,0,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><DockPanel><TextBlock Text="◉  Preview" FontSize="16" FontWeight="SemiBold" Foreground="#15155A"/><Button DockPanel.Dock="Right" Content="⚙ Display Settings" Foreground="#4E5873"/></DockPanel><Border Grid.Row="1" Background="#F8F8FC" BorderBrush="#E2E3EB" BorderThickness="1" CornerRadius="8,8,0,0" Padding="12" Margin="0,16,0,0"><Grid><TextBlock Text="Preview (Full Song)" HorizontalAlignment="Center" Foreground="#5B4DEA" FontWeight="SemiBold"/><TextBlock Text="Preview (Stanzas)" HorizontalAlignment="Right" Foreground="#4E5873"/></Grid></Border><Border Grid.Row="2" Background="White" BorderBrush="#E2E3EB" BorderThickness="1" CornerRadius="0,0,8,8" Padding="28"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel><TextBlock Text="Song preview" FontSize="23" Foreground="#14175B" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,22"/><TextBlock Text="Select a song to see its lyrics here." TextWrapping="Wrap" Foreground="#353C55" FontSize="15" TextAlignment="Center"/></StackPanel></ScrollViewer></Border><Grid Grid.Row="3" Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Button Content="A-"/><Button Grid.Column="1" Content="Font Size&#x0a;100%"/><Button Grid.Column="2" Content="A+"/></Grid></Grid></Border>
     </Grid>
     <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="1.35*"/></Grid.ColumnDefinitions><Border Style="{StaticResource BibleCard}" Padding="12" Margin="0,0,7,0"><StackPanel><TextBlock Text="▣  Created On" Foreground="#5B4DEA"/><TextBlock Text="20 May 2024 10:30 AM" Foreground="#59617A" Margin="0,5,0,0"/></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource BibleCard}" Padding="12" Margin="7,0"><StackPanel><TextBlock Text="✎  Last Modified" Foreground="#5B4DEA"/><TextBlock Text="22 May 2024 04:15 PM" Foreground="#59617A" Margin="0,5,0,0"/></StackPanel></Border><Border Grid.Column="2" Style="{StaticResource BibleCard}" Padding="12" Margin="7,0"><StackPanel><TextBlock Text="▥  Total Usage" Foreground="#5B4DEA"/><TextBlock Text="23 times in planners" Foreground="#59617A" Margin="0,5,0,0"/></StackPanel></Border><Border Grid.Column="3" Style="{StaticResource BibleCard}" Padding="10" Margin="7,0,0,0"><StackPanel><TextBlock Text="Quick Actions" Foreground="#15155A" FontWeight="SemiBold"/><WrapPanel><Button Content="Duplicate Song" Foreground="#5B4DEA"/><Button Content="Export" Foreground="#16A34A"/><Button Content="Delete" Foreground="#EF4444" Click="DeleteAllSongs_Click"/></WrapPanel></StackPanel></Border></Grid>
   </Grid>

