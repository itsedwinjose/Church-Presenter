<UserControl x:Class="Church_Presenter.Views.Planner.ServiceStatistics"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Style="{StaticResource Card}">
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" >
      <StackPanel>
        <TextBlock Text="22 Components" FontWeight="SemiBold"/>
        <TextBlock Text="6 Songs" Foreground="{StaticResource MutedTextBrush}"/>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="2 Bible Readings" FontWeight="SemiBold"/>
        <TextBlock Text="5 Media" Foreground="{StaticResource MutedTextBrush}"/>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="78 Minutes" FontWeight="SemiBold"/>
        <TextBlock Text="Estimated Duration" Foreground="{StaticResource MutedTextBrush}"/>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
