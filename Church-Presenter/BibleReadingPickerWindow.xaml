<Window x:Class="Church_Presenter.BibleReadingPickerWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Choose Bible reading" Width="820" Height="610" WindowStartupLocation="CenterOwner" Background="#F8FAFC">
 <Grid Margin="20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <StackPanel><TextBlock Text="Add Bible reading" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="Choose the testament, book, chapter, and verse range for this service." Foreground="#64748B" Margin="0,5,0,16"/></StackPanel>
  <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Testament"/><ComboBox x:Name="TestamentBox" SelectionChanged="Testament_Changed"><ComboBoxItem Content="Old"/><ComboBoxItem Content="New"/></ComboBox></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="Book"/><ComboBox x:Name="BookBox" DisplayMemberPath="Name" SelectionChanged="Book_Changed"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Chapter"/><ComboBox x:Name="ChapterBox" SelectionChanged="Chapter_Changed"/></StackPanel><StackPanel Grid.Column="3"><TextBlock Text="From verse"/><ComboBox x:Name="FromVerseBox" SelectionChanged="VerseRange_Changed"/></StackPanel><StackPanel Grid.Column="4"><TextBlock Text="To verse"/><ComboBox x:Name="ToVerseBox" SelectionChanged="VerseRange_Changed"/></StackPanel></Grid>
  <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16" Margin="0,16,0,16"><ScrollViewer VerticalScrollBarVisibility="Auto"><TextBlock x:Name="PreviewText" Text="Choose a passage to preview it here." TextWrapping="Wrap" FontSize="16"/></ScrollViewer></Border>
  <DockPanel Grid.Row="3"><TextBlock Text="The selected passage is copied into this planner and remains editable there." Foreground="#64748B" VerticalAlignment="Center"/><StackPanel Orientation="Horizontal" DockPanel.Dock="Right"><Button Content="Cancel" IsCancel="True"/><Button Content="Add to plan" Click="Add_Click" IsDefault="True" Background="#0284C7" Foreground="White"/></StackPanel></DockPanel>
 </Grid>
</Window>
