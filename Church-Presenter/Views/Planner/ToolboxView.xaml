<UserControl x:Class="Church_Presenter.Views.Planner.ToolboxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Church_Presenter.ViewModels">
  <Border Style="{StaticResource Card}" Padding="10">
    <StackPanel>
      <TextBlock Text="Add Components" FontWeight="SemiBold"/>
      <TextBox Margin="0,8,0,12" Text="Search components..." Foreground="{StaticResource MutedTextBrush}"/>
      <ItemsControl ItemsSource="{Binding Toolbox}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,6" Padding="8" Background="#FBFBFE" CornerRadius="8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="36"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="36" Height="36" Background="#EEF2FF" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="8,0">
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</UserControl>
