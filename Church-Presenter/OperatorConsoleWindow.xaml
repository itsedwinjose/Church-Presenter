<Window x:Class="Church_Presenter.OperatorConsoleWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Presentation Console" Width="1300" Height="780" WindowStartupLocation="CenterOwner" Background="#111827">
 <Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
  <Border Background="#1F2937" CornerRadius="8" Padding="12"><DockPanel><StackPanel DockPanel.Dock="Top"><TextBlock Text="SERVICE ORDER" Foreground="#93C5FD" FontWeight="Bold"/><TextBlock Text="Select an item, choose how it displays, then play it." Foreground="#CBD5E1" TextWrapping="Wrap" Margin="0,8"/></StackPanel><ListBox x:Name="ComponentList" SelectionChanged="Component_Selected" Background="Transparent" Foreground="White" BorderThickness="0"><ListBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal"><TextBlock Width="22" Text="✓" Foreground="#93C5FD" FontWeight="Bold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsCompleted}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock><TextBlock Text="{Binding DisplayTitle}" TextWrapping="Wrap"/></StackPanel></DataTemplate></ListBox.ItemTemplate></ListBox></DockPanel></Border>
  <Grid Grid.Column="1" Margin="16,0,0,0">
    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <Border x:Name="PreviewSurface" Background="#101828" CornerRadius="8" Padding="48">
      <ScrollViewer x:Name="PreviewScroller" VerticalScrollBarVisibility="Disabled">
        <StackPanel VerticalAlignment="Center">
          <TextBlock x:Name="PreviewTitle" Text="Select a component" Foreground="White" FontSize="40" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"/>
          <TextBlock x:Name="PreviewContent" Foreground="White" FontSize="30" Margin="0,28,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>
      </ScrollViewer>
    </Border>
    <DockPanel Grid.Row="1" Margin="0,14,0,0">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="Display mode:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <ComboBox x:Name="DisplayModeBox" Width="150" SelectionChanged="DisplayMode_Changed"><ComboBoxItem Content="Static"/><ComboBoxItem Content="Scrollable"/></ComboBox>
        <TextBlock x:Name="ScreenStatus" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="18,0,0,0"/>
        <TextBlock Text="Speed:" Foreground="White" VerticalAlignment="Center" Margin="18,0,6,0"/>
        <Button Content="-" Width="28" Height="28" Click="DecreaseSpeed_Click"/>
        <TextBlock x:Name="ScrollSpeedDisplay" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="6,0" Text="2" />
        <Button Content="+" Width="28" Height="28" Click="IncreaseSpeed_Click"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
        <Button Content="Clear preview" Click="ClearPreview_Click" Margin="0,0,8,0"/>
        <Button x:Name="PresentationToggleButton" Content="Open presenter" Click="TogglePresentation_Click" Margin="0,0,8,0"/>
        <Button Content="Close" Click="CloseConsole_Click" Margin="0,0,8,0"/>
        <ToggleButton x:Name="PlayPauseToggle" Content="Play" Click="PlayPause_Click" Background="#0284C7" Foreground="White" Padding="16,9"/>
      </StackPanel>
    </DockPanel>
  </Grid>
 </Grid>
</Window>
