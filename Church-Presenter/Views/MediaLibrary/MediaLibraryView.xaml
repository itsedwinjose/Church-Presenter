<UserControl x:Class="Church_Presenter.Views.MediaLibrary.MediaLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Church_Presenter.ViewModels"
             xmlns:local="clr-namespace:Church_Presenter.Views.MediaLibrary"
             Background="#F5F7FB">
    <UserControl.DataContext>
        <vm:MediaLibraryViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="SectionCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PanelBorder" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Setter Property="Padding" Value="14"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="3" Style="{StaticResource CardBorder}" Background="White"/>

            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="50" Height="50" Background="#EEF2FF" CornerRadius="14">
                            <TextBlock Text="🖼" FontSize="24" Foreground="#5B5CEB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Media Library" FontSize="30" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock Text="Manage Images, Videos and Audio for Presentations" Foreground="#64748B" FontSize="13" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <local:SearchBar Grid.Column="1" VerticalAlignment="Center"/>
                </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Folders" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="＋" Style="{StaticResource IconButton}" Margin="0,0,4,0"/>
                                <Button Content="✎" Style="{StaticResource IconButton}" Margin="0,0,4,0"/>
                                <Button Content="🗑" Style="{StaticResource IconButton}"/>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Folders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <local:FolderCard/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="#FBFCFF" BorderBrush="#E9EDF8" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Tags" Style="{StaticResource SectionCaption}"/>
                                <ItemsControl ItemsSource="{Binding FilterTags}" Margin="0,10,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F5F3FF" CornerRadius="10" Padding="8,4" Margin="0,0,6,6">
                                                <TextBlock Text="{Binding Name}" Foreground="#5B5CEB" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <local:Toolbar/>
                        <local:FilterPanel Grid.Row="1"/>

                        <Border Grid.Row="2" Background="#FBFCFF" BorderBrush="#E9EDF8" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Planner-safe media browser" Foreground="#1E293B" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="•" Foreground="#CBD5E1" Margin="10,0"/>
                                <TextBlock Text="Double-click preview, context menu, selection, favorite state and type badges shown with placeholder data." Foreground="#64748B" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DisplayedMedia}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <local:MediaCard/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Grid Grid.Row="4" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding PageSummary}" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="«" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                                <Button Content="1" Style="{StaticResource PrimaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                                <Button Content="2" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                                <Button Content="3" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                                <Button Content="10" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,6,0"/>
                                <Button Content="»" Style="{StaticResource SecondaryButton}" Padding="10,6"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <local:PreviewPanel/>
                        <local:DetailsPanel/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <local:StatusCard Title="Images" Value="245" Icon="🖼" Margin="0,0,10,0"/>
                    <local:StatusCard Title="Videos" Value="56" Icon="🎬" Margin="0,0,10,0"/>
                    <local:StatusCard Title="Audio" Value="138" Icon="♫" Margin="0,0,10,0"/>
                    <local:StatusCard Title="Storage Used" Value="8.6 GB" Icon="💾" Margin="0,0,10,0"/>
                    <local:StatusCard Title="Favorites" Value="42" Icon="★" Margin="0,0,10,0"/>
                    <local:StatusCard Title="Recently Added" Value="16" Icon="⏱"/>
                </ItemsControl>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Preview" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Duplicate" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Copy Path" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Move" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Export" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Delete" Style="{StaticResource SecondaryButton}" Foreground="#DC2626" BorderBrush="#FECACA"/>
                </StackPanel>
            </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
