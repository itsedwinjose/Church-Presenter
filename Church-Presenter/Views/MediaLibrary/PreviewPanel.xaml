<UserControl x:Class="Church_Presenter.Views.MediaLibrary.PreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Church_Presenter.Models">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type models:ImageItem}">
            <Border Height="148" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F97316" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock Text="✝" Foreground="White" FontSize="58" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:VideoItem}">
            <Border Height="148" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#111827" Offset="0"/>
                        <GradientStop Color="#6366F1" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Border Width="56" Height="56" Background="#55FFFFFF" CornerRadius="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="▶" Foreground="White" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:AudioItem}">
            <Border Height="148" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#9333EA" Offset="0"/>
                        <GradientStop Color="#EC4899" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="♫" Foreground="White" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Waveform" Foreground="#F5F3FF" FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Border Style="{DynamicResource CardBorder}" Padding="14" Margin="0,0,0,14">
        <StackPanel>
            <TextBlock Text="Preview" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
            <ContentControl Content="{Binding SelectedMedia}" Margin="0,12,0,0"/>
            <TextBlock Text="{Binding SelectedMedia.FileName}" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,12,0,0"/>
            <TextBlock Text="{Binding SelectedMedia.MetaLine}" Foreground="#64748B" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
