<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Font Families -->
    <FontFamily x:Key="PrimaryFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>

    <!-- Font Sizes -->
    <system:Double x:Key="FontSizeDisplay" xmlns:system="clr-namespace:System;assembly=mscorlib">28</system:Double>
    <system:Double x:Key="FontSizeTitle" xmlns:system="clr-namespace:System;assembly=mscorlib">20</system:Double>
    <system:Double x:Key="FontSizeSubtitle" xmlns:system="clr-namespace:System;assembly=mscorlib">16</system:Double>
    <system:Double x:Key="FontSizeBase" xmlns:system="clr-namespace:System;assembly=mscorlib">14</system:Double>
    <system:Double x:Key="FontSizeSmall" xmlns:system="clr-namespace:System;assembly=mscorlib">12</system:Double>
    <system:Double x:Key="FontSizeCaption" xmlns:system="clr-namespace:System;assembly=mscorlib">11</system:Double>

    <!-- Font Weights -->
    <FontWeight x:Key="FontWeightThin">Thin</FontWeight>
    <FontWeight x:Key="FontWeightLight">Light</FontWeight>
    <FontWeight x:Key="FontWeightNormal">Normal</FontWeight>
    <FontWeight x:Key="FontWeightMedium">Medium</FontWeight>
    <FontWeight x:Key="FontWeightSemiBold">SemiBold</FontWeight>
    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>

    <!-- Line Heights -->
    <system:Double x:Key="LineHeightRelaxed" xmlns:system="clr-namespace:System;assembly=mscorlib">1.5</system:Double>
    <system:Double x:Key="LineHeightTight" xmlns:system="clr-namespace:System;assembly=mscorlib">1.2</system:Double>

</ResourceDictionary>
