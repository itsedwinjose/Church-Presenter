<UserControl x:Class="Church_Presenter.Views.Planner.PlannerHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="0,0,0,12">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="360"/>
    </Grid.ColumnDefinitions>
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
      <Border Width="44" Height="44" Background="{StaticResource AccentBrush}" CornerRadius="10" HorizontalAlignment="Left" VerticalAlignment="Center">
        <TextBlock Text="?" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="18"/>
      </Border>
      <StackPanel Margin="12,0">
        <TextBlock Text="Planner" FontSize="20" FontWeight="SemiBold"/>
        <TextBlock Text="Build and organize your worship service." Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" >
      <DatePicker Width="150"/>
      <ComboBox Width="160">
        <ComboBoxItem Content="Sunday Morning Worship"/>
        <ComboBoxItem Content="Evening Service"/>
      </ComboBox>
      <Button Content="New Planner" Style="{StaticResource PrimaryButton}"/>
      <Button Content="Duplicate"/>
      <Button Content="Save" Style="{StaticResource PrimaryButton}"/>
      <Button Content="Preview"/>
      <Button Content="Start" Style="{StaticResource PrimaryButton}"/>
    </StackPanel>
  </Grid>
</UserControl>
