<Window x:Class="Church_Presenter.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Church Presenter" Height="800" Width="1300" MinHeight="650" MinWidth="1000" Background="#F8FAFC" WindowState="Maximized">
 <Window.Resources>
  <Style TargetType="Button"><Setter Property="Padding" Value="12,8"/><Setter Property="Margin" Value="4"/></Style>
  <Style x:Key="Nav" TargetType="Button"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#CBD5E1"/><Setter Property="BorderThickness" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="FontSize" Value="15"/></Style>
  <Style TargetType="TextBox"><Setter Property="Padding" Value="8"/><Setter Property="Margin" Value="4"/></Style>
  <Style TargetType="ComboBox"><Setter Property="Padding" Value="7"/><Setter Property="Margin" Value="4"/></Style>
 </Window.Resources>
 <Grid>
  <Grid.ColumnDefinitions>
    <ColumnDefinition Width="220"/>
    <ColumnDefinition Width="*"/>
  </Grid.ColumnDefinitions>

  <Border Background="#0F172A">
    <DockPanel>
      <StackPanel DockPanel.Dock="Top" Margin="20,28,12,18">
        <TextBlock Text="CHURCH" Foreground="#38BDF8" FontWeight="Bold" FontSize="14"/>
        <TextBlock Text="Presenter" Foreground="White" FontWeight="SemiBold" FontSize="26"/>
      </StackPanel>
      <StackPanel>
        <Button Style="{StaticResource Nav}" Click="Dashboard_Click">Dashboard</Button>
        <Button Style="{StaticResource Nav}" Click="Planner_Click">Planner</Button>
        <Button Style="{StaticResource Nav}" Click="Bible_Click">Bible Library</Button>
        <Button Style="{StaticResource Nav}" Click="Library_Click">Song + Media</Button>
        <Button Style="{StaticResource Nav}" Click="Theme_Click">Themes</Button>
        <Button Style="{StaticResource Nav}" Click="Settings_Click">Settings</Button>
      </StackPanel>
      <TextBlock DockPanel.Dock="Bottom" Margin="20" Text="OFFLINE • SQLITE" Foreground="#64748B" FontSize="11"/>
    </DockPanel>
  </Border>

  <Grid Grid.Column="1" Margin="30">

   <Grid x:Name="DashboardPanel">
     <StackPanel>
       <TextBlock Text="Good morning" FontSize="31" FontWeight="SemiBold"/>
       <TextBlock Text="Prepare a calm, focused service." Foreground="#64748B" Margin="0,6,0,24"/>
       <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="24">
         <StackPanel>
           <TextBlock Text="TODAY'S PLANNER" Foreground="#64748B" FontSize="12" FontWeight="Bold"/>
           <TextBlock Text="Create a service planner, then add components." FontSize="20" Margin="0,12,0,14"/>
           <Button Content="New Planner" Click="Planner_Click" Background="#0284C7" Foreground="White" HorizontalAlignment="Left"/>
         </StackPanel>
       </Border>
     </StackPanel>
   </Grid>

   <Grid x:Name="PlannerPanel" Visibility="Collapsed">
     <Grid.RowDefinitions>
       <RowDefinition Height="Auto"/>
       <RowDefinition Height="Auto"/>
       <RowDefinition Height="*"/>
     </Grid.RowDefinitions>
     <DockPanel>
       <StackPanel>
         <TextBlock Text="Service Planner" FontSize="31" FontWeight="SemiBold"/>
         <TextBlock Text="Build and save the ordered flow for a service." Foreground="#64748B" Margin="0,6,0,14"/>
       </StackPanel>
       <Button DockPanel.Dock="Right" Content="Present selected" Click="PresentComponent_Click" Background="#0284C7" Foreground="White"/>
     </DockPanel>
     <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10">
       <WrapPanel>
         <TextBlock Text="Service:" VerticalAlignment="Center" Margin="6"/>
         <TextBox x:Name="ServiceNameBox" Text="Sunday Service" Width="180"/>
         <TextBlock Text="Date:" VerticalAlignment="Center" Margin="6"/>
         <DatePicker x:Name="ServiceDatePicker" SelectedDateChanged="PlannerIdentity_Changed"/>
         <Button Content="Load / create planner" Click="LoadPlanner_Click"/>
       </WrapPanel>
     </Border>
     <Grid Grid.Row="2" Margin="0,16,0,0">
       <Grid.ColumnDefinitions>
         <ColumnDefinition Width="240"/>
         <ColumnDefinition Width="*"/>
         <ColumnDefinition Width="330"/>
       </Grid.ColumnDefinitions>
       <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12">
         <ScrollViewer VerticalScrollBarVisibility="Auto">
           <StackPanel>
             <TextBlock Text="ADD COMPONENT" FontWeight="Bold" Foreground="#64748B" FontSize="12"/>
             <Button Tag="Heading" Content="+ Heading" Click="AddComponent_Click"/>
             <Button Tag="Paragraph" Content="+ Paragraph" Click="AddComponent_Click"/>
             <Button Tag="Song" Content="+ Song" Click="AddComponent_Click"/>
             <Button Tag="Bible Reading" Content="+ Bible Reading" Click="AddComponent_Click"/>
             <Button Tag="Image" Content="+ Image" Click="AddComponent_Click"/>
             <Button Tag="Image + Text" Content="+ Image + Text" Click="AddComponent_Click"/>
             <Button Tag="Video" Content="+ Video" Click="AddComponent_Click"/>
             <Button Tag="Music" Content="+ Music" Click="AddComponent_Click"/>
             <Button Tag="Announcement" Content="+ Announcement" Click="AddComponent_Click"/>
             <Button Tag="Blank Screen" Content="+ Blank Screen" Click="AddComponent_Click"/>
             <Button Tag="Countdown" Content="+ Countdown" Click="AddComponent_Click"/>
           </StackPanel>
         </ScrollViewer>
       </Border>
       <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="8" Margin="14,0">
         <DockPanel>
           <TextBlock DockPanel.Dock="Top" Text="SERVICE ORDER" FontWeight="Bold" Foreground="#64748B" FontSize="12" Margin="8"/>
           <ListBox x:Name="PlannerList" DisplayMemberPath="DisplayTitle" SelectionChanged="PlannerComponent_Selected" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
         </DockPanel>
       </Border>
       <Border Grid.Column="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="14">
         <ScrollViewer VerticalScrollBarVisibility="Auto">
           <StackPanel>
             <TextBlock x:Name="ComponentTypeLabel" Text="Select a component" FontWeight="SemiBold" FontSize="17"/>
             <TextBlock Text="Title" Margin="0,14,0,0"/>
             <TextBox x:Name="ComponentTitleBox"/>
             <TextBlock Text="Text, lyrics, Bible reference or file path" Margin="0,10,0,0"/>
             <TextBox x:Name="ComponentContentBox" Height="160" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
             <WrapPanel Margin="0,12,0,0">
               <Button Content="Save changes" Click="SaveComponent_Click" Background="#0284C7" Foreground="White"/>
               <Button Content="Move up" Click="MoveUp_Click"/>
               <Button Content="Move down" Click="MoveDown_Click"/>
               <Button Content="Remove" Click="RemoveComponent_Click"/>
             </WrapPanel>
           </StackPanel>
         </ScrollViewer>
       </Border>
     </Grid>
   </Grid>

   <Grid x:Name="BiblePanel" Visibility="Collapsed">
     <Grid.RowDefinitions>
       <RowDefinition Height="Auto"/>
       <RowDefinition Height="Auto"/>
       <RowDefinition Height="*"/>
     </Grid.RowDefinitions>
     <DockPanel>
       <StackPanel>
         <TextBlock Text="Bible Library" FontSize="31" FontWeight="SemiBold"/>
         <TextBlock Text="Tamil Unicode Bible, arranged by book, chapter and verse." Foreground="#64748B" Margin="0,6,0,16"/>
       </StackPanel>
       <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
        <Button Content="Delete all Bible data" Click="DeleteAllBible_Click" Foreground="#B91C1C"/>
        <Button Content="Import CSV Bible" Click="ImportBible_Click" Background="#0284C7" Foreground="White"/>
       </StackPanel>
     </DockPanel>
     <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12">
       <Grid>
         <Grid.ColumnDefinitions>
           <ColumnDefinition Width="2*"/>
           <ColumnDefinition Width="*"/>
           <ColumnDefinition Width="2*"/>
         </Grid.ColumnDefinitions>
         <ComboBox x:Name="BookBox" DisplayMemberPath="Name" SelectionChanged="Book_Changed"/>
         <ComboBox x:Name="ChapterBox" Grid.Column="1" SelectionChanged="Chapter_Changed"/>
         <TextBox x:Name="SearchBox" Grid.Column="2" TextChanged="Search_Changed" ToolTip="Search Bible text"/>
       </Grid>
     </Border>
     <Grid Grid.Row="2" Margin="0,18,0,0">
       <Grid.ColumnDefinitions>
         <ColumnDefinition Width="*"/>
         <ColumnDefinition Width="285"/>
       </Grid.ColumnDefinitions>
       <ListBox x:Name="VerseList" SelectionChanged="Verse_Selected" BorderBrush="#E2E8F0" Background="White">
         <ListBox.ItemTemplate>
           <DataTemplate>
             <StackPanel Margin="12,8">
               <TextBlock Text="{Binding Reference}" FontWeight="SemiBold" Foreground="#0369A1"/>
               <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,4,0,0"/>
             </StackPanel>
           </DataTemplate>
         </ListBox.ItemTemplate>
       </ListBox>
       <Border Grid.Column="1" Background="#EFF6FF" Margin="16,0,0,0" CornerRadius="8" Padding="20">
         <StackPanel>
           <TextBlock Text="Presentation queue" FontSize="17" FontWeight="SemiBold"/>
           <TextBlock Text="Select a verse, then present it using your chosen display style." TextWrapping="Wrap" Foreground="#475569" Margin="0,10"/>
           <Button Content="Present selected verse" Click="PresentVerse_Click" Background="#0284C7" Foreground="White"/>
         </StackPanel>
       </Border>
     </Grid>
   </Grid>

   <Grid x:Name="SettingsPanel" Visibility="Collapsed">
     <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Width="620">
       <TextBlock Text="Display settings" FontSize="31" FontWeight="SemiBold"/>
       <TextBlock Text="These defaults are saved locally and used by the fullscreen presentation window." Foreground="#64748B" Margin="0,6,0,20"/>
       <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20">
         <StackPanel>
           <TextBlock Text="Background color (hex)"/>
           <TextBox x:Name="BackgroundColorBox"/>
           <TextBlock Text="Font color (hex)" Margin="0,12,0,0"/>
           <TextBox x:Name="FontColorBox"/>
         </StackPanel>
       </Border>
       <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,16,0,0">
         <StackPanel>
           <TextBlock Text="Presentation font size"/>
           <Slider x:Name="FontSizeSlider" Minimum="24" Maximum="120" TickFrequency="2" IsSnapToTickEnabled="True" Margin="0,12"/>
           <TextBlock x:Name="FontSizeLabel"/>

           <TextBlock Text="Scroll speed (px / tick)" Margin="0,12,0,0"/>
           <Slider x:Name="ScrollSpeedSlider" Minimum="1" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,8"/>
           <TextBlock x:Name="ScrollSpeedLabel"/>

           <WrapPanel Margin="0,12,0,0">
             <Button Content="Save display settings" Click="SaveSettings_Click" Background="#0284C7" Foreground="White"/>
             <Button Content="Preview" Click="Preview_Click"/>
           </WrapPanel>
         </StackPanel>
       </Border>
       <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,16,0,0">
         <StackPanel>
           <TextBlock Text="Content-specific typography" FontSize="18" FontWeight="SemiBold"/>
           <TextBlock Text="Set a font size and hex color for each type of presentation content." Foreground="#64748B" Margin="0,4,0,12"/>
           <Grid>
             <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
             <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
             <TextBlock Grid.Column="1" Text="Font size" Margin="4"/><TextBlock Grid.Column="2" Text="Font color (hex)" Margin="4"/>
             <TextBlock Grid.Row="1" Text="Heading" VerticalAlignment="Center" Margin="4"/>
             <TextBox x:Name="HeadingFontSizeBox" Grid.Row="1" Grid.Column="1" ToolTip="Font size"/>
             <TextBox x:Name="HeadingFontColorBox" Grid.Row="1" Grid.Column="2" ToolTip="Hex color, e.g. #FFFFFF"/>
             <TextBlock Grid.Row="2" Text="Paragraph" VerticalAlignment="Center" Margin="4"/>
             <TextBox x:Name="ParagraphFontSizeBox" Grid.Row="2" Grid.Column="1" ToolTip="Font size"/>
             <TextBox x:Name="ParagraphFontColorBox" Grid.Row="2" Grid.Column="2" ToolTip="Hex color, e.g. #FFFFFF"/>
             <TextBlock Grid.Row="3" Text="Bible reading" VerticalAlignment="Center" Margin="4"/>
             <TextBox x:Name="BibleReadingFontSizeBox" Grid.Row="3" Grid.Column="1" ToolTip="Font size"/>
             <TextBox x:Name="BibleReadingFontColorBox" Grid.Row="3" Grid.Column="2" ToolTip="Hex color, e.g. #FFFFFF"/>
             <TextBlock Grid.Row="4" Text="Song lyrics" VerticalAlignment="Center" Margin="4"/>
             <TextBox x:Name="SongLyricsFontSizeBox" Grid.Row="4" Grid.Column="1" ToolTip="Font size"/>
             <TextBox x:Name="SongLyricsFontColorBox" Grid.Row="4" Grid.Column="2" ToolTip="Hex color, e.g. #FFFFFF"/>
           </Grid>
         </StackPanel>
       </Border>
      </StackPanel>
     </ScrollViewer>
   </Grid>

   <Grid x:Name="OtherPanel" Visibility="Collapsed">
     <Grid.RowDefinitions>
       <RowDefinition Height="Auto"/>
       <RowDefinition Height="*"/>
     </Grid.RowDefinitions>
     <StackPanel>
       <TextBlock x:Name="OtherTitle" Text="Song + Media Library" FontSize="31" FontWeight="SemiBold"/>
       <TextBlock x:Name="OtherSubtitle" Text="Add songs and media once, then reuse them in any planner." Foreground="#64748B" Margin="0,6,0,16"/>
     </StackPanel>
     <Grid Grid.Row="1">
       <Grid.ColumnDefinitions>
         <ColumnDefinition Width="*"/>
         <ColumnDefinition Width="*"/>
       </Grid.ColumnDefinitions>
       <Border x:Name="SongLibraryCard" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,8,0">
         <Grid>
           <Grid.RowDefinitions>
             <RowDefinition Height="Auto"/>
             <RowDefinition Height="Auto"/>
             <RowDefinition Height="*"/>
             <RowDefinition Height="Auto"/>
             <RowDefinition Height="150"/>
           </Grid.RowDefinitions>
           <TextBlock Text="SONG LIBRARY" FontWeight="Bold" Foreground="#64748B" FontSize="12"/>
           <TextBox x:Name="SongTitleBox" Grid.Row="1" ToolTip="Song title"/>
           <TextBox x:Name="SongLyricsBox" Grid.Row="2" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" ToolTip="Lyrics (separate stanzas with blank lines)"/>
           <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Save song" Click="SaveSong_Click" Background="#0284C7" Foreground="White" HorizontalAlignment="Left"/>
            <Button Content="Delete all songs" Click="DeleteAllSongs_Click" Foreground="#B91C1C"/>
           </StackPanel>
           <ListBox x:Name="SongList" Grid.Row="4" DisplayMemberPath="DisplayTitle" SelectionChanged="Song_Selected"/>
         </Grid>
       </Border>
       <Border x:Name="MediaLibraryCard" Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="16" Margin="8,0,0,0">
         <Grid>
           <Grid.RowDefinitions>
             <RowDefinition Height="Auto"/>
             <RowDefinition Height="Auto"/>
             <RowDefinition Height="Auto"/>
             <RowDefinition Height="Auto"/>
             <RowDefinition Height="150"/>
           </Grid.RowDefinitions>
           <TextBlock Text="MEDIA LIBRARY" FontWeight="Bold" Foreground="#64748B" FontSize="12"/>
           <ComboBox x:Name="MediaTypeBox" Grid.Row="1" SelectedIndex="0"><ComboBoxItem Content="Image"/><ComboBoxItem Content="Video"/><ComboBoxItem Content="Music"/></ComboBox>
           <TextBox x:Name="MediaTitleBox" Grid.Row="2" ToolTip="Display name"/>
           <WrapPanel Grid.Row="3"><Button Content="Choose file and save" Click="SaveMedia_Click" Background="#0284C7" Foreground="White"/></WrapPanel>
           <ListBox x:Name="MediaList" Grid.Row="4" DisplayMemberPath="DisplayTitle" SelectionChanged="Media_Selected"/>
         </Grid>
       </Border>
     </Grid>
   </Grid>

  </Grid>
 </Grid>
</Window>
