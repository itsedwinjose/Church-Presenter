<UserControl x:Class="Church_Presenter.Views.MediaLibrary.MediaCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Church_Presenter.Models"
             xmlns:local="clr-namespace:Church_Presenter.Views.MediaLibrary">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type models:ImageItem}">
            <local:ImageCard/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:VideoItem}">
            <local:VideoCard/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:AudioItem}">
            <local:AudioCard/>
        </DataTemplate>
    </UserControl.Resources>
    <ContentControl Content="{Binding}"/>
</UserControl>
