<UserControl x:Class="Church_Presenter.UserControls.ImageCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="240" d:DesignWidth="180">
    <Border Style="{StaticResource MediaCardBorder}" 
            Background="{DynamicResource BackgroundLightBrush}"
            BorderBrush="{DynamicResource BorderLightBrush}"
            BorderThickness="1" CornerRadius="12">
        <Grid>
            <!-- Thumbnail -->
            <Border Background="{DynamicResource BackgroundDarkBrush}" 
                    CornerRadius="8" Margin="8,8,8,0" Height="120">
                <Grid Background="#E0E0E0">
                    <TextBlock Text="🖼️" FontSize="48" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Opacity="0.5"/>
                </Grid>
            </Border>

            <!-- Favorite Star (Top Right) -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Margin="0,12,12,0" Style="{StaticResource IconButton}"
                    Content="★" FontSize="16" Foreground="#FFD700"/>

            <!-- File Type Badge (Bottom Right of Thumbnail) -->
            <Border Background="{DynamicResource PrimaryBrush}" 
                    CornerRadius="4" Padding="4,2"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,120,12,0">
                <TextBlock Text="{Binding FileTypeDisplay}" 
                           Foreground="White" FontSize="10" FontWeight="Bold"/>
            </Border>

            <!-- Info Bottom -->
            <StackPanel VerticalAlignment="Bottom" Margin="8,0,8,8">
                <!-- File Name -->
                <TextBlock Text="{Binding FileName}" 
                           FontFamily="{DynamicResource PrimaryFont}"
                           FontSize="{DynamicResource FontSizeSmall}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Resolution -->
                <TextBlock Text="{Binding ResolutionDisplay}" 
                           FontFamily="{DynamicResource PrimaryFont}"
                           FontSize="{DynamicResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,2,0,0"/>

                <!-- File Size -->
                <TextBlock Text="{Binding FileSizeDisplay}" 
                           FontFamily="{DynamicResource PrimaryFont}"
                           FontSize="{DynamicResource FontSizeCaption}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
