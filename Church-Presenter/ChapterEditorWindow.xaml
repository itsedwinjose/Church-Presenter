<Window x:Class="Church_Presenter.ChapterEditorWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Bible chapter" Width="500" Height="300" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F8FAFC"><Grid Margin="22"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock x:Name="HeadingText" Text="Bible chapter" FontSize="24" FontWeight="SemiBold"/><TextBlock x:Name="SubtitleText" Grid.Row="1" Text="Enter the chapter details." Foreground="#64748B" Margin="0,6,0,0" TextWrapping="Wrap"/><Grid Grid.Row="2" Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,8,0"><TextBlock Text="Book"/><ComboBox x:Name="BookBox" DisplayMemberPath="Name"/></StackPanel><StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="Chapter number"/><TextBox x:Name="ChapterNumberBox"/></StackPanel></Grid><DockPanel Grid.Row="3" Margin="0,18,0,0"><Button Content="Cancel" IsCancel="True" DockPanel.Dock="Right"/><Button x:Name="SaveButton" Content="Save" Click="Save_Click" IsDefault="True" DockPanel.Dock="Right" Background="#0284C7" Foreground="White"/></DockPanel></Grid></Window>
