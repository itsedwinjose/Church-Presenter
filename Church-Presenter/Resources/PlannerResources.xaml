<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Colors -->
  <Color x:Key="AccentColor">#5B5CEB</Color>
  <Color x:Key="SurfaceColor">#FFFFFF</Color>
  <Color x:Key="MutedText">#64748B</Color>
  <Color x:Key="BorderColor">#E6E9F2</Color>

  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
  <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedText}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

  <!-- Fonts -->
  <FontFamily x:Key="PrimaryFont">Segoe UI Variable</FontFamily>

  <!-- Radii -->
  <CornerRadius x:Key="CardRadius">12</CornerRadius>
  <CornerRadius x:Key="ButtonRadius">10</CornerRadius>

  <!-- Shadow (simple) -->
  <DropShadowEffect x:Key="SubtleShadow" BlurRadius="10" ShadowDepth="2" Color="#20000000"/>

  <!-- Card Style -->
  <Style x:Key="Card" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="CornerRadius" Value="{StaticResource CardRadius}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="12"/>
  </Style>

  <!-- Button -->
  <Style x:Key="PrimaryButton" TargetType="Button">
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}" CornerRadius="{StaticResource ButtonRadius}" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Small icon text -->
  <Style x:Key="IconText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
  </Style>

  <!-- Planner item style -->
  <Style x:Key="PlannerItemCard" TargetType="Border" BasedOn="{StaticResource Card}">
    <Setter Property="Margin" Value="0,6"/>
  </Style>
</ResourceDictionary>
