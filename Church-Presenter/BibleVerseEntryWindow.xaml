<Window x:Class="Church_Presenter.BibleVerseEntryWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Bible verse" Width="580" Height="570" WindowStartupLocation="CenterOwner" Background="#F8FAFC"><Grid Margin="22"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock x:Name="HeadingText" Text="Bible verse" FontSize="24" FontWeight="SemiBold"/><TextBlock x:Name="SubtitleText" Grid.Row="1" Text="Enter Bible verse details." Foreground="#64748B" Margin="0,6,0,0" TextWrapping="Wrap"/><Grid Grid.Row="2" Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Testament"/><ComboBox x:Name="TestamentBox" SelectedIndex="0"><ComboBoxItem Content="Old"/><ComboBoxItem Content="New"/></ComboBox></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="Book name"/><TextBox x:Name="BookBox"/></StackPanel></Grid><Grid Grid.Row="3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Chapter"/><TextBox x:Name="ChapterBox"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="Verse"/><TextBox x:Name="VerseBox"/></StackPanel></Grid><TextBlock Grid.Row="4" Text="Verse text (Tamil supported)" Margin="0,12,0,0"/><Grid Grid.Row="5"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBox x:Name="VerseTextBox" Grid.Row="0" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" MinHeight="260"/><DockPanel Grid.Row="1" Margin="0,16,0,0"><Button Content="Cancel" IsCancel="True" DockPanel.Dock="Right"/><Button x:Name="SaveButton" Content="Save verse" Click="Save_Click" IsDefault="True" DockPanel.Dock="Right" Background="#0284C7" Foreground="White"/></DockPanel></Grid></Grid></Window>
