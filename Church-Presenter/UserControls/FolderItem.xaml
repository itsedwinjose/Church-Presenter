<UserControl x:Class="Church_Presenter.UserControls.FolderItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="50" d:DesignWidth="250">
    <Grid>
        <StackPanel Orientation="Horizontal" Margin="12,8">
            <!-- Folder Icon -->
            <TextBlock Text="📁" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>

            <!-- Folder Name -->
            <StackPanel VerticalAlignment="Center" Margin="0">
                <TextBlock FontFamily="{DynamicResource PrimaryFont}" 
                           FontSize="{DynamicResource FontSizeBase}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Text="{Binding Name}"/>
            </StackPanel>

            <!-- Count -->
            <Label Background="{DynamicResource BackgroundDarkBrush}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="{DynamicResource FontSizeCaption}"
                   Padding="6,2" Margin="Auto,0,0,0"
                   Content="{Binding MediaCount}"/>
        </StackPanel>
    </Grid>
</UserControl>
