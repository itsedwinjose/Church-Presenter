<Window x:Class="Church_Presenter.ChapterEditorWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Bible chapter" Width="560" Height="430" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F8FAFC"><Grid Margin="22"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock x:Name="HeadingText" Text="Bible chapter" FontSize="24" FontWeight="SemiBold"/><TextBlock x:Name="SubtitleText" Grid.Row="1" Text="Enter the chapter details." Foreground="#64748B" Margin="0,6,0,0" TextWrapping="Wrap"/><Grid Grid.Row="2" Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,8,0"><TextBlock Text="Chapter number"/><TextBox x:Name="ChapterNumberBox"/></StackPanel><StackPanel x:Name="VerseNumberPanel" Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="First verse number"/><TextBox x:Name="VerseNumberBox" Text="1"/></StackPanel></Grid><TextBlock x:Name="VerseTextLabel" Grid.Row="3" Text="First verse text" Margin="0,12,0,0"/><TextBox x:Name="VerseTextBox" Grid.Row="4" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/><DockPanel Grid.Row="5" Margin="0,18,0,0"><Button Content="Cancel" IsCancel="True" DockPanel.Dock="Right"/><Button x:Name="SaveButton" Content="Save" Click="Save_Click" IsDefault="True" DockPanel.Dock="Right" Background="#0284C7" Foreground="White"/></DockPanel></Grid></Window>