<UserControl x:Class="Church_Presenter.Views.MediaLibrary.FilterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ComboBox Grid.Column="0" ItemsSource="{Binding MediaTypeTabs}" SelectedItem="{Binding SelectedMediaType}" Margin="0,0,10,0"/>
        <ComboBox Grid.Column="1" ItemsSource="{Binding FileFormats}" SelectedItem="{Binding SelectedFileFormat}" Margin="0,0,10,0"/>
        <ComboBox Grid.Column="2" ItemsSource="{Binding AspectRatios}" SelectedItem="{Binding SelectedAspectRatio}" Margin="0,0,10,0"/>
        <ComboBox Grid.Column="3" SelectedItem="{Binding SelectedTag}">
            <ComboBoxItem Content="All Tags"/>
            <ComboBoxItem Content="Christmas"/>
            <ComboBoxItem Content="Youth"/>
            <ComboBoxItem Content="Bible"/>
            <ComboBoxItem Content="Praise"/>
            <ComboBoxItem Content="Welcome"/>
        </ComboBox>
    </Grid>
</UserControl>
