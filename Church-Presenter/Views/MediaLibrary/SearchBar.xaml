<UserControl x:Class="Church_Presenter.Views.MediaLibrary.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="White" BorderBrush="#E4E8F5" BorderThickness="1" CornerRadius="10" Padding="12,9" Margin="0,0,12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="⌕" Foreground="#94A3B8" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding SearchText}" Foreground="#94A3B8" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="8,3">
                    <TextBlock Text="Ctrl + F" Foreground="#64748B" FontSize="11" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>
        <Button Grid.Column="1" Content="Import" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
        <Button Grid.Column="2" Content="New Folder" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
        <Button Grid.Column="3" Content="Refresh" Style="{DynamicResource PrimaryButton}"/>
    </Grid>
</UserControl>
