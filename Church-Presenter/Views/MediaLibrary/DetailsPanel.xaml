<UserControl x:Class="Church_Presenter.Views.MediaLibrary.DetailsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Border Style="{DynamicResource CardBorder}" Padding="14" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Details" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="92"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Category" Foreground="#64748B" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedMedia.DetailOneValue}" Foreground="#1E293B" FontSize="12" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Text="Tags" Foreground="#64748B" FontSize="12" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedMedia.DetailTwoValue}" Foreground="#1E293B" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="2" Text="Created" Foreground="#64748B" FontSize="12" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedMedia.CreatedDisplay}" Foreground="#1E293B" FontSize="12" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="3" Text="Added By" Foreground="#64748B" FontSize="12" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedMedia.AddedBy}" Foreground="#1E293B" FontSize="12" Margin="0,8,0,0"/>
                </Grid>
                <TextBlock Text="Actions" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,14,0,8"/>
                <Button Content="Edit Details" Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8"/>
                <Button Content="Replace File" Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8"/>
                <Button Content="Add to Favorites" Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8"/>
                <Button Content="Move to Folder" Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8"/>
                <Button Content="Delete File" Style="{DynamicResource SecondaryButton}" Foreground="#DC2626" BorderBrush="#FECACA"/>
            </StackPanel>
        </Border>
        <Border Style="{DynamicResource CardBorder}" Padding="14" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Editable Fields" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                <TextBlock Text="Filename" Foreground="#64748B" FontSize="12" Margin="0,12,0,4"/>
                <TextBox Text="{Binding SelectedMedia.FileName}"/>
                <TextBlock Text="Description" Foreground="#64748B" FontSize="12" Margin="0,10,0,4"/>
                <TextBox Text="{Binding SelectedMedia.Description}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"/>
                <TextBlock Text="Category" Foreground="#64748B" FontSize="12" Margin="0,10,0,4"/>
                <TextBox Text="{Binding SelectedMedia.Category}"/>
                <TextBlock Text="Tags" Foreground="#64748B" FontSize="12" Margin="0,10,0,4"/>
                <TextBox Text="{Binding SelectedMedia.TagsDisplay, Mode=OneWay}" IsReadOnly="True"/>
                <TextBlock Text="Theme" Foreground="#64748B" FontSize="12" Margin="0,10,0,4"/>
                <TextBox Text="{Binding SelectedMedia.Theme}"/>
                <TextBlock Text="Stretch Mode" Foreground="#64748B" FontSize="12" Margin="0,10,0,4"/>
                <ComboBox ItemsSource="{Binding StretchModes}" SelectedItem="{Binding SelectedMedia.StretchMode}"/>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Background Opacity" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SelectedMedia.BackgroundOpacity}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Rotation" Foreground="#64748B" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SelectedMedia.Rotation}"/>
                    </StackPanel>
                </Grid>
                <CheckBox Content="Favorite" IsChecked="{Binding SelectedMedia.IsFavorite}" Margin="0,12,0,0" Foreground="#1E293B"/>
            </StackPanel>
        </Border>
        <Border Style="{DynamicResource CardBorder}" Padding="14">
            <StackPanel>
                <TextBlock Text="Usage in Planners (3)" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                <TextBlock Text="{Binding SelectedMedia.UsedInDisplay}" Foreground="#475569" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                <Button Content="View All" Style="{DynamicResource SecondaryButton}" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

