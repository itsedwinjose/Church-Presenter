<Window x:Class="Church_Presenter.PresentationWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" WindowStyle="None" Topmost="True">
  <Grid x:Name="Stage">
    <ScrollViewer x:Name="ContentScroller" VerticalScrollBarVisibility="Disabled" CanContentScroll="False">
      <StackPanel VerticalAlignment="Top" Margin="80">
        <TextBlock x:Name="ContentText" TextAlignment="Center" TextWrapping="Wrap"/>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
