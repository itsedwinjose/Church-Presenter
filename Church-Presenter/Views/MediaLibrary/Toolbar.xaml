<UserControl x:Class="Church_Presenter.Views.MediaLibrary.Toolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal">
            <Border Background="#EEF2FF" CornerRadius="10" Padding="10,5" Margin="0,0,8,0">
                <TextBlock Text="All Media   156" Foreground="#4F46E5" FontWeight="SemiBold" FontSize="12"/>
            </Border>
            <Border Background="#F8FAFC" CornerRadius="10" Padding="10,5" Margin="0,0,8,0">
                <TextBlock Text="Images   86" Foreground="#334155" FontWeight="SemiBold" FontSize="12"/>
            </Border>
            <Border Background="#F8FAFC" CornerRadius="10" Padding="10,5" Margin="0,0,8,0">
                <TextBlock Text="Videos   34" Foreground="#334155" FontWeight="SemiBold" FontSize="12"/>
            </Border>
            <Border Background="#F8FAFC" CornerRadius="10" Padding="10,5">
                <TextBlock Text="Audio   36" Foreground="#334155" FontWeight="SemiBold" FontSize="12"/>
            </Border>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
            <ComboBox Width="170" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}" Margin="0,0,10,0"/>
            <Button Content="▦" Style="{DynamicResource SecondaryButton}" Padding="12,8" Margin="0,0,8,0"/>
            <Button Content="☰" Style="{DynamicResource SecondaryButton}" Padding="12,8" Margin="0,0,8,0"/>
            <Button Content="Large" Style="{DynamicResource SecondaryButton}" Padding="12,8" Margin="0,0,8,0"/>
            <Button Content="Small" Style="{DynamicResource SecondaryButton}" Padding="12,8"/>
        </StackPanel>
    </Grid>
</UserControl>
