<UserControl x:Class="Church_Presenter.Views.MediaLibrary.AudioCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{DynamicResource MediaCardBorder}" Width="174" Margin="0,0,12,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="118"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border CornerRadius="10" Margin="0,0,0,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#A855F7" Offset="0"/>
                        <GradientStop Color="#F472B6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Border Width="54" Height="54" Background="#33FFFFFF" CornerRadius="27" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="♫" Foreground="White" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#22000000" CornerRadius="8" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                        <TextBlock Text="{Binding DurationDisplay}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#22000000" CornerRadius="8" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                        <TextBlock Text="{Binding FavoriteGlyph}" Foreground="#FACC15" FontSize="12"/>
                    </Border>
                </Grid>
            </Border>
            <StackPanel Grid.Row="1">
                <TextBlock Text="{Binding FileName}" Foreground="#1E293B" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding MediaType}" Foreground="#C026D3" FontSize="11" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding BitrateDisplay}" Foreground="#64748B" FontSize="11" Margin="0,2,0,0"/>
                <TextBlock Text="{Binding FileSizeDisplay}" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
