<UserControl x:Class="Church_Presenter.Views.MediaLibrary.FolderCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Border x:Name="RootBorder" Padding="10,8" Margin="0,0,0,6" CornerRadius="10" BorderThickness="1">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F8F7FF"/>
                        <Setter Property="BorderBrush" Value="#E5E7F5"/>
                    </Trigger>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Background" Value="#EEF0FF"/>
                        <Setter Property="BorderBrush" Value="#D8DEFF"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="34"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Width="28" Height="28" CornerRadius="8" Background="#F4F1FF" VerticalAlignment="Center">
                <TextBlock Text="{Binding Icon}" Foreground="#5B5CEB" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#1E293B" FontWeight="SemiBold" FontSize="13"/>
            <Border Grid.Column="2" Background="#F8FAFC" CornerRadius="10" Padding="8,3" VerticalAlignment="Center">
                <TextBlock Text="{Binding CountDisplay}" Foreground="#64748B" FontSize="11" FontWeight="SemiBold"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
