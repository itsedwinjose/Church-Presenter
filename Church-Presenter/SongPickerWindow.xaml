<Window x:Class="Church_Presenter.SongPickerWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Choose a song" Width="820" Height="570" WindowStartupLocation="CenterOwner" Background="#F8FAFC">
 <Grid Margin="20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <StackPanel><TextBlock Text="Add song to planner" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="Search by Tamil or English title, select a song, then add a copy of its lyrics to this service." Foreground="#64748B" Margin="0,5,0,12"/><TextBox x:Name="SearchBox" TextChanged="Search_Changed" Padding="9" ToolTip="Search songs"/></StackPanel>
  <Grid Grid.Row="1" Margin="0,14,0,14"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><ListBox x:Name="SongList" DisplayMemberPath="DisplayTitle" SelectionChanged="Song_Selected"/><Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16" Margin="14,0,0,0"><StackPanel><TextBlock x:Name="TitleText" Text="Select a song" FontSize="20" FontWeight="SemiBold"/><TextBox x:Name="LyricsBox" Margin="0,12,0,0" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="Transparent"/></StackPanel></Border></Grid>
  <DockPanel Grid.Row="2"><TextBlock Text="The planner receives its own editable copy; the library song is not changed." Foreground="#64748B" VerticalAlignment="Center"/><StackPanel Orientation="Horizontal" DockPanel.Dock="Right"><Button Content="Cancel" IsCancel="True" Padding="14,8" Margin="4"/><Button Content="Add to plan" Click="Add_Click" IsDefault="True" Background="#0284C7" Foreground="White" Padding="14,8" Margin="4"/></StackPanel></DockPanel>
 </Grid>
</Window>
