<UserControl x:Class="Church_Presenter.Views.Planner.PropertyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Style="{StaticResource Card}">
    <StackPanel>
      <TextBlock Text="Component Properties" FontWeight="SemiBold"/>
      <Border Margin="0,8,0,8" Background="#FAFBFF" CornerRadius="8" Padding="8">
        <StackPanel>
          <TextBlock Text="No item selected" Foreground="{StaticResource MutedTextBrush}"/>
        </StackPanel>
      </Border>

      <StackPanel>
        <TextBlock Text="Dynamic properties would show here." Foreground="{StaticResource MutedTextBrush}"/>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
