<UserControl x:Class="Church_Presenter.UserControls.StatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="800">
    <Border Background="{DynamicResource BackgroundDarkBrush}" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource BorderLightBrush}">
        <Grid Margin="16,12">
            <StackPanel Orientation="Horizontal">
                <!-- Images Count -->
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="🖼️" FontSize="20"/>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="Images" FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalImages}" FontWeight="SemiBold"
                                   FontSize="{DynamicResource FontSizeBase}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Videos Count -->
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="🎬" FontSize="20"/>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="Videos" FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalVideos}" FontWeight="SemiBold"
                                   FontSize="{DynamicResource FontSizeBase}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Audio Count -->
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="♪" FontSize="20"/>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="Audio" FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalAudio}" FontWeight="SemiBold"
                                   FontSize="{DynamicResource FontSizeBase}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Storage Used -->
                <StackPanel Orientation="Horizontal" Margin="Auto,0,0,0">
                    <TextBlock Text="💾" FontSize="20"/>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="Storage" FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding StorageUsed}" FontWeight="SemiBold"
                                   FontSize="{DynamicResource FontSizeBase}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
