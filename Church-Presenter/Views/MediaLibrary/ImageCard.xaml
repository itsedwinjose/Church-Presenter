<UserControl x:Class="Church_Presenter.Views.MediaLibrary.ImageCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{DynamicResource MediaCardBorder}" Width="174" Margin="0,0,12,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="118"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border CornerRadius="10" Margin="0,0,0,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F59E0B" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Border Background="#22000000" CornerRadius="8" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                        <TextBlock Text="🖼" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#22000000" CornerRadius="8" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                        <TextBlock Text="{Binding FavoriteGlyph}" Foreground="#FACC15" FontSize="12"/>
                    </Border>
                    <TextBlock Text="{Binding FileTypeDisplay}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10" Foreground="White" FontWeight="Bold" FontSize="11"/>
                </Grid>
            </Border>
            <StackPanel Grid.Row="1">
                <TextBlock Text="{Binding FileName}" Foreground="#1E293B" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding MediaType}" Foreground="#5B5CEB" FontSize="11" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding ResolutionDisplay}" Foreground="#64748B" FontSize="11" Margin="0,2,0,0"/>
                <TextBlock Text="{Binding FileSizeDisplay}" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
