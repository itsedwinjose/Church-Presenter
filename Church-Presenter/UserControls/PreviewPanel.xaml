<UserControl x:Class="Church_Presenter.UserControls.PreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="300">
    <Border Style="{StaticResource CardBorder}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <!-- Preview Image -->
                <Border Background="{DynamicResource BackgroundDarkBrush}" 
                        CornerRadius="12" Margin="0,0,0,16" Height="180">
                    <TextBlock Text="🖼️" FontSize="72" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Opacity="0.3"/>
                </Border>

                <!-- File Name -->
                <TextBlock Text="File Name" FontWeight="SemiBold" 
                           FontSize="{DynamicResource FontSizeSmall}"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding SelectedMedia.FileName}" 
                           FontSize="{DynamicResource FontSizeBase}"
                           Foreground="{DynamicResource TextPrimaryBrush}" 
                           Margin="0,4,0,16" TextWrapping="Wrap"/>

                <!-- Details -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- File Size -->
                    <TextBlock Text="File Size" FontWeight="SemiBold" 
                               FontSize="{DynamicResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding SelectedMedia.FileSizeDisplay}" 
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource TextPrimaryBrush}" 
                               Grid.Column="1" HorizontalAlignment="Right"/>

                    <!-- Category -->
                    <TextBlock Text="Category" FontWeight="SemiBold" 
                               FontSize="{DynamicResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               Grid.Row="1" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding SelectedMedia.Category}" 
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource TextPrimaryBrush}" 
                               Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Margin="0,12,0,0"/>

                    <!-- Created Date -->
                    <TextBlock Text="Created" FontWeight="SemiBold" 
                               FontSize="{DynamicResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               Grid.Row="2" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding SelectedMedia.CreatedDate, StringFormat='M/d/yyyy H:mm'}" 
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource TextPrimaryBrush}" 
                               Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Margin="0,12,0,0"/>
                </Grid>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource BorderLightBrush}" Margin="0,0,0,16"/>

                <!-- Quick Actions -->
                <StackPanel>
                    <Button Content="Preview" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Replace File" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Add to Favorites" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Move" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Delete" Style="{StaticResource SecondaryButton}" 
                            Foreground="{DynamicResource ErrorBrush}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
